# Remove the top and right spines from the plots
axes.spines.right: False
axes.spines.top: False


# Color palette configuration
image.lut: 256
axes.prop_cycle: cycler("color", ["#AF3029",  "#5E409D", "#BC5215", "#AD8301" , "#66800B", "#24837B", "#205EA6", "#A02F6F", "#000000", "#666666"])

# Retina figures configuration
figure.dpi: 300
savefig.dpi: 300

# Font sizes
font.size: 14
axes.titlesize: 16
axes.labelsize: 14
xtick.labelsize: 13
ytick.labelsize: 13
legend.fontsize: 14

# Font family configuration
font.family: sans-serif

# Specify a list of fonts for the 'sans-serif' generic family, in order of preference
font.sans-serif: Roboto, DejaVu Sans, Bitstream Vera Sans, Computer Modern Sans Serif, Arial, Liberation Sans, Helvetica
